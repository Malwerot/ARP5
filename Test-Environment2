local function findNearestPot()
    local char = LocalPlayer.Character
    if not char or not char:FindFirstChild("HumanoidRootPart") then return nil end
    local myPos = char.HumanoidRootPart.Position
    local closest, shortestDist = nil, 35 

    local locs = {
        Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Houses") and Workspace.Map.Houses:FindFirstChild("WH1") and Workspace.Map.Houses.WH1:FindFirstChild("Interior"),
        Workspace:FindFirstChild("Map") and Workspace.Map:FindFirstChild("Locations") and Workspace.Map.Locations:FindFirstChild("Apartments") and Workspace.Map.Locations.Apartments:FindFirstChild("Home 1"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 2"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 3"),
        Workspace.Map.Locations.Apartments:FindFirstChild("Home 4")
    }

    for _, loc in ipairs(locs) do
        if loc then
            for _, child in ipairs(loc:GetChildren()) do
                if child.Name == "Cooking Pot" and child:IsA("BasePart") then
                    local dist = (child.Position - myPos).Magnitude
                    if dist < shortestDist then shortestDist = dist; closest = child end
                end
            end
        end
    end
    return closest
end

local function equipItem(itemName)
    local char = LocalPlayer.Character; local bp = LocalPlayer:FindFirstChild("Backpack")
    if not char or not char:FindFirstChild("Humanoid") or not bp then return false end
    if char:FindFirstChild(itemName) then return true end
    local tool = bp:FindFirstChild(itemName)
    if tool then char.Humanoid:EquipTool(tool); return true end
    return false
end

local Actions = {}
function Actions.Procurar()
    targetPot = findNearestPot()
    return targetPot ~= nil
end

function Actions.ExecutarReceita()
    for _, item in ipairs(farmItems) do
        if not isFarming then return "abortado" end
        if not targetPot or not targetPot.Parent then return "panela_sumiu" end

        local equipped, tentativas = false, 0
        while not equipped and isFarming and tentativas < 5 do
            equipped = equipItem(item.name)
            if not equipped then tentativas = tentativas + 1; randomWait(3, 5) end
        end

        if not equipped then return "falha_estoque" end
        randomWait(1.1, 2.3)
        
        pcall(function()
            local prompt = targetPot:FindFirstChild("Attachment") and targetPot.Attachment:FindFirstChild("ProximityPrompt")
            if prompt then fireproximityprompt(prompt) end
        end)

        task.wait(item.cooldown + (math.random(15, 42) / 10))
    end
    return "sucesso"
end

