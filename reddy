-- MortyHub: Headsize-All (Anti-Crash Version)

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer
local enabled = false
local currentSize = 9
local originalSizes = {}

-- --- INTERFACE GUI ---
local gui = Instance.new("ScreenGui", localPlayer:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local btn = Instance.new("TextButton", gui)
btn.Size = UDim2.new(0, 150, 0, 45)
btn.Position = UDim2.new(0.8, 0, 0.1, 0)
btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
btn.TextColor3 = Color3.new(1, 1, 1)
btn.Text = "MortyHub: OFF"
btn.Font = Enum.Font.SourceSansBold
btn.TextScaled = true

local corner = Instance.new("UICorner", btn)
corner.CornerRadius = UDim.new(0, 10)

-- --- LÓGICA PRINCIPAL ---

local function applyHeadsize(player)
    if not enabled or player == localPlayer then return end
    
    local char = player.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            -- Salva o tamanho original apenas uma vez
            if not originalSizes[player] then
                originalSizes[player] = head.Size
            end

            -- AJUSTES ANTI-CRASH:
            -- Mantemos CanTouch/CanQuery para a bala detectar a cabeça,
            -- mas desligamos CanCollide para a cabeça não bater no cenário.
            head.CanCollide = false 
            head.CanTouch = true    
            head.CanQuery = true    
            head.Massless = true    
            
            -- Aplica o tamanho gigante
            head.Size = Vector3.new(currentSize, currentSize, currentSize)
            
            -- Remove travas de redimensionamento do Roblox
            local oSize = head:FindFirstChild("OriginalSize")
            if oSize then oSize:Destroy() end
        end
    end
end

local function resetHeadsize(player)
    local char = player.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            head.Size = originalSizes[player] or Vector3.new(2, 1, 1)
            head.CanCollide = true
            head.Massless = false
        end
    end
end

-- --- GESTÃO DE PLAYERS ---

local function onCharacterAdded(player)
    player.CharacterAdded:Connect(function()
        task.wait(0.5) -- Espera o personagem carregar os componentes
        if enabled then
            applyHeadsize(player)
        end
    end)
end

-- Configura jogadores atuais e futuros
for _, p in pairs(Players:GetPlayers()) do
    onCharacterAdded(p)
    if p.Character then applyHeadsize(p) end
end

Players.PlayerAdded:Connect(onCharacterAdded)

-- --- BOTÃO TOGGLE ---

btn.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        btn.Text = "MortyHub: ON"
        btn.BackgroundColor3 = Color3.fromRGB(0, 180, 50)
        -- Aplica em todos imediatamente
        for _, p in pairs(Players:GetPlayers()) do
            applyHeadsize(p)
        end
    else
        btn.Text = "MortyHub: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(40, 40, 40)
        -- Reseta todos imediatamente
        for _, p in pairs(Players:GetPlayers()) do
            resetHeadsize(p)
        end
    end
end)

-- --- LOOP DE VERIFICAÇÃO (OPCIONAL/SEGURO) ---
-- Em vez de RenderStepped, verificamos a cada 2 segundos se alguém resetou
task.spawn(function()
    while true do
        task.wait(2)
        if enabled then
            for _, p in pairs(Players:GetPlayers()) do
                if p ~= localPlayer then
                    applyHeadsize(p)
                end
            end
        end
    end
end)
