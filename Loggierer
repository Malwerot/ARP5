-- [[ TESTADOR DE COMPRA EM MASSA - AXIOS ]]
local quantidade = 10 -- Mude para quanto você quer comprar
local itemNome = "Water" -- Nome exato que aparece no botão da imagem

local function tentarComprar()
    -- Procura o Remote de Loja no ReplicatedStorage (lugar mais comum)
    local remote = game:GetService("ReplicatedStorage"):FindFirstChild("ShopRemote", true) 
                   or game:GetService("ReplicatedStorage"):FindFirstChild("Purchase", true)
                   or game:GetService("ReplicatedStorage"):FindFirstChild("BuyItem", true)

    if remote then
        print("Remote encontrado: " .. remote.Name)
        for i = 1, quantidade do
            -- A estrutura comum é: Remote:FireServer(ItemNome, Quantidade)
            -- Ou apenas: Remote:FireServer(ItemNome) em loop
            remote:FireServer(itemNome)
            task.wait(0.05)
        end
    else
        warn("Não foi possível encontrar o Remote automaticamente. Tente abrir a loja antes de rodar.")
    end
end

tentarComprar()
