local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()
local Window = Library.CreateLib("Axios - God Farm", "Midnight")
local Tab = Window:NewTab("Auto Farm")
local Section = Tab:NewSection("Modificadores de Tarefa")

Section:NewToggle("Interação Instantânea", "Tira o tempo de segurar o E", function(state)
    _G.Instant = state
    task.spawn(function()
        while _G.Instant do
            for _, v in pairs(workspace:GetDescendants()) do
                if v:IsA("ProximityPrompt") then
                    v.HoldDuration = 0 -- Não precisa mais segurar!
                end
            end
            task.wait(2)
        end
    end)
end)

Section:NewToggle("Auto-Desgrudar", "Pula e desancora ao interagir", function(state)
    _G.AntiFreeze = state
end)

-- Lógica para desgrudar automaticamente ao terminar uma ação
game:GetService("ProximityPromptService").PromptButtonHoldEnded:Connect(function(prompt, player)
    if _G.AntiFreeze and player == game.Players.LocalPlayer then
        task.wait(0.1)
        local char = player.Character
        if char then
            char.HumanoidRootPart.Anchored = false
            char.Humanoid:ChangeState(Enum.HumanoidStateType.Jumping)
        end
    end
end)

print("Novo sistema carregado. Tente a Interação Instantânea!")
