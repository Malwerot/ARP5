local function notify(title, text, duration)
    pcall(function() game:GetService("StarterGui"):SetCore("SendNotification", {Title = title, Text = text, Duration = duration or 4}) end)
end

local function randomWait(min, max) task.wait(math.random(min * 100, max * 100) / 100) end

local function countItems(itemName)
    local count = 0
    local bp = LocalPlayer:FindFirstChild("Backpack")
    local char = LocalPlayer.Character
    local items = bp and bp:GetChildren() or {}
    if char then for _, v in ipairs(char:GetChildren()) do if v:IsA("Tool") then table.insert(items, v) end end end
    for _, item in ipairs(items) do if item.Name == itemName then count = count + 1 end end
    return count
end

local function calcularVendaTotal()
    local totalDinheiro, quantidadeTotal = 0, 0
    local containers = {LocalPlayer:FindFirstChild("Backpack"), LocalPlayer.Character}
    for _, folder in ipairs(containers) do
        if folder then
            for _, item in ipairs(folder:GetChildren()) do
                if PRECOS_BAGS[item.Name] then totalDinheiro = totalDinheiro + PRECOS_BAGS[item.Name]; quantidadeTotal = quantidadeTotal + 1 end
            end
        end
    end
    return totalDinheiro, quantidadeTotal
end

local function ModifyTheme(theme)
    if not MainFrame then return end
    
    -- 1. Atualiza as cores base da janela
    MainFrame.BackgroundColor3 = theme.Background
    if SideBar then SideBar.BackgroundColor3 = theme.Topbar end

    -- 2. o neon
    -- Ele procura os dois Strokes (o fino e o de brilho e aplica a cor do tema
    for _, child in ipairs(MainFrame:GetChildren()) do
        if child:IsA("UIStroke") then
            child.Color = theme.ElementStroke
            -- Se o brilho for grande, ele fica mais suave (tipo um neon real :O)
            child.Transparency = (child.Thickness > 2) and 0.5 or 0.1
        end
    end

    -- 2. Varredura completa dos elementos no Huub
    for _, obj in ipairs(MainFrame:GetDescendants()) do
        pcall(function()
            -- Lógica de botões
            if obj:IsA("TextButton") and obj.Name ~= "CloseBtn" then
                obj.BackgroundColor3 = theme.ElementBackground
                obj.TextColor3 = theme.TextColor

            -- Neon nos botões, se o botão tiver um contorno ele brilha também
                local bStroke = obj:FindFirstChildOfClass("UIStroke")
                if bStroke then bStroke.Color = theme.ElementStroke end

          elseif obj:IsA("Frame") and (obj.Name == "DropFrame" or obj.Parent:IsA("ScrollingFrame")) then
              obj.BackgroundColor3 = theme.ElementBackground

             local dStroke = obj:FindFirstChildOfClass("UIStroke")
             if dStroke then dStroke.Color = theme.ElementStroke end

            -- [ Lógica de Textos ]
            elseif obj:IsA("TextLabel") then
                obj.TextColor3 = theme.TextColor
                
                if string.find(obj.Text, "——") then
                    obj.TextColor3 = theme.ElementStroke
                end

                if obj.Parent:IsA("ScrollingFrame") then
                    obj.BackgroundColor3 = theme.ElementBackground
                    obj.BackgroundTransparency = 0
                else
                    obj.BackgroundTransparency = 1
                  end
              end
          end)
      end
  end
-- Fim da função ModifyTheme

