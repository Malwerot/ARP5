        else
            TextBox.Text = ""
            TextBox.PlaceholderText = "WRONG KEY!"
            task.wait(1)
            TextBox.PlaceholderText = "Enter Key..."
        end
    end)

    repeat task.wait() until KeySystem.Status == true
end

