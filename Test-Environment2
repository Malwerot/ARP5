        local s = Instance.new("UIStroke", b)
        s.Color = Themes.Default.ElementStroke
        s.Thickness = 1
        s.ApplyStrokeMode = Enum.ApplyStrokeMode.Border

        local act = false
        b.MouseButton1Click:Connect(function() 
            act = not act
            b.Text = n .. (act and ": ON" or ": OFF")
            b.TextColor3 = act and Color3.fromRGB(0, 255, 150) or Color3.fromRGB(180, 180, 180)
