local UIS = game:GetService("UserInputService")
local VIM = game:GetService("VirtualInputManager")
local Player = game:GetService("Players").LocalPlayer
local PlayerGui = Player:WaitForChild("PlayerGui")

-- [ INTERFACE ]
local ScreenGui = Instance.new("ScreenGui")
ScreenGui.Name = "AutoF_ToggleUI"
ScreenGui.Parent = PlayerGui
ScreenGui.ResetOnSpawn = false

local Main = Instance.new("Frame", ScreenGui)
Main.Size = UDim2.new(0, 300, 0, 100) -- Aumentei um pouco para caber o botão
Main.Position = UDim2.new(0.02, 0, 0.8, 0)
Main.BackgroundColor3 = Color3.fromRGB(40, 0, 80)
Main.Active = true
Main.Draggable = true
Instance.new("UICorner", Main)

local Title = Instance.new("TextLabel", Main)
Title.Text = "AUTO-F (SHIFT + HOLD)"
Title.Size = UDim2.new(1, 0, 0.5, 0)
Title.TextColor3 = Color3.new(1, 1, 1)
Title.BackgroundTransparency = 1
Title.TextSize = 14

-- [ BOTÃO TOGGLE ]
local ToggleBtn = Instance.new("TextButton", Main)
ToggleBtn.Size = UDim2.new(0, 200, 0, 30)
ToggleBtn.Position = UDim2.new(0.5, -100, 0.6, 0)
ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0) -- Começa vermelho (OFF)
ToggleBtn.Text = "STATUS: OFF"
ToggleBtn.TextColor3 = Color3.new(1, 1, 1)
ToggleBtn.Font = Enum.Font.SourceSansBold
Instance.new("UICorner", ToggleBtn)

-- [ VARIÁVEIS DE CONTROLE ]
local autoF_Enabled = false
local shiftPressionado = false

-- Função do Toggle
ToggleBtn.MouseButton1Click:Connect(function()
    autoF_Enabled = not autoF_Enabled
    if autoF_Enabled then
        ToggleBtn.Text = "STATUS: ON"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(0, 200, 100) -- Verde
    else
        ToggleBtn.Text = "STATUS: OFF"
        ToggleBtn.BackgroundColor3 = Color3.fromRGB(200, 0, 0) -- Vermelho
    end
end)

-- [ DETECÇÃO DE SHIFT ]
UIS.InputBegan:Connect(function(input, gameProcessed)
    if gameProcessed then return end
    if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
        shiftPressionado = true
    end
end)

UIS.InputEnded:Connect(function(input)
    if input.KeyCode == Enum.KeyCode.LeftShift or input.KeyCode == Enum.KeyCode.RightShift then
        shiftPressionado = false
    end
end)

-- [ LOOP DE EXECUÇÃO ]
task.spawn(function()
    while true do
        -- Só aperta F se o Toggle estiver ON E o Shift estiver segurado
        if autoF_Enabled and shiftPressionado then
            -- Simula o pressionamento
            VIM:SendKeyEvent(true, Enum.KeyCode.F, false, game)
            task.wait(0.05)
            VIM:SendKeyEvent(false, Enum.KeyCode.F, false, game)
        end
        task.wait(0.5) -- Intervalo de 0.5 segundos
    end
end)

print("Script carregado! Ative o botão e segure Shift.")
