task.spawn(function()
    while true do
        if not isFarming then 
            currentState = States.IDLE 
        else
            if currentState == States.IDLE then
                currentState = States.BUSCANDO
            elseif currentState == States.BUSCANDO then
                if Actions.Procurar() then currentState = States.FARMANDO else task.wait(4) end
            elseif currentState == States.FARMANDO then
                local res = Actions.ExecutarReceita()
                if res == "sucesso" then 
                    randomWait(2, 4); currentState = States.BUSCANDO
                elseif res == "falha_estoque" then 
                    isFarming = false; currentState = States.IDLE
                    notify("AXIOS", "Farm parado: Sem itens")
                elseif res == "panela_sumiu" then 
                    currentState = States.BUSCANDO 
                end
            end
        end
        task.wait(0.2)
