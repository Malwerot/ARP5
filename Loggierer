local LogService = game:GetService("LogService")

print("--- LOGGER INICIADO: Abra o Console (F9) para ver as interações ---")

-- Metatabela para "ganchar" (hook) as chamadas de RemoteEvents
local oldNamecall
oldNamecall = hookmetamethod(game, "__namecall", function(self, ...)
    local method = getnamecallmethod()
    local args = {...}
    
    -- Filtra apenas por eventos de disparo (FireServer é o mais comum para compras)
    if method == "FireServer" or method == "InvokeServer" then
        -- Aqui filtramos nomes comuns que jogos usam para lojas/inventário
        -- Se quiser ver TUDO, pode remover o 'if' e deixar apenas o print
        print("--------------------------------")
        print("EVENTO DISPARADO: " .. self.Name)
        print("CAMINHO: " .. self:GetFullName())
        
        -- Mostra os argumentos (o que está sendo enviado: ex: "Water", 10)
        for i, v in pairs(args) do
            print("ARG [" .. i .. "]:", v)
        end
    end
    
    return oldNamecall(self, ...)
end)
