-- Headsize-All Otimizado (Sem Crash ao Atirar)

local Players = game:GetService("Players")
local localPlayer = Players.LocalPlayer

local enabled = false
local currentSize = 9
local originalSizes = {}

-- GUI
local gui = Instance.new("ScreenGui", localPlayer:WaitForChild("PlayerGui"))
gui.ResetOnSpawn = false

local btn = Instance.new("TextButton", gui)
btn.Size = UDim2.new(0, 120, 0, 40)
btn.Position = UDim2.new(0.8, 0, 0.1, 0)
btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
btn.Text = "MortyHub: OFF"
btn.TextColor3 = Color3.new(1,1,1)
btn.Font = Enum.Font.SourceSansBold
btn.TextScaled = true

-- Função principal para aplicar o tamanho com segurança
local function applyHeadsize(player)
    if not enabled or player == localPlayer then return end
    
    local char = player.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            -- Salva o tamanho original uma única vez
            if not originalSizes[player] then
                originalSizes[player] = head.Size
            end

            -- Aplica as mudanças
            head.Size = Vector3.new(currentSize, currentSize, currentSize)
            head.CanCollide = false
            head.Massless = true
            
            -- Remove o valor que o Roblox usa para "corrigir" o tamanho automaticamente
            local originalSizeValue = head:FindFirstChild("OriginalSize")
            if originalSizeValue then
                originalSizeValue:Destroy()
            end
        end
    end
end

-- Função para resetar
local function resetHeadsize(player)
    local char = player.Character
    if char then
        local head = char:FindFirstChild("Head")
        if head and head:IsA("BasePart") then
            head.Size = originalSizes[player] or Vector3.new(2, 1, 1)
            head.CanCollide = true
            head.Massless = false
        end
    end
end

-- Conectar eventos de spawn (ESSENCIAL PARA NÃO PRECISAR DE LOOP)
local function onCharacterAdded(player)
    player.CharacterAdded:Connect(function()
        task.wait(0.5) -- Espera o personagem carregar os assets
        if enabled then
            applyHeadsize(player)
        end
    end)
end

-- Inicializa jogadores atuais e futuros
for _, p in pairs(Players:GetPlayers()) do
    onCharacterAdded(p)
end
Players.PlayerAdded:Connect(onCharacterAdded)

-- Lógica do Botão
btn.MouseButton1Click:Connect(function()
    enabled = not enabled
    if enabled then
        btn.Text = "MortyHub: ON"
        btn.BackgroundColor3 = Color3.fromRGB(0, 200, 50)
        -- Aplica em todo mundo que já está no mapa
        for _, p in pairs(Players:GetPlayers()) do
            applyHeadsize(p)
        end
    else
        btn.Text = "MortyHub: OFF"
        btn.BackgroundColor3 = Color3.fromRGB(50, 50, 50)
        for _, p in pairs(Players:GetPlayers()) do
            resetHeadsize(p)
        end
    end
end)
